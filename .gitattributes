* text=auto

*.json text eol=lf
*.lock text eol=lf
*.md text eol=lf
*.rs text eol=lf
*.toml text eol=lf

# The test sshd image + its config must stay LF; a CRLF sshd_config breaks sshd.
docker/test-sshd/Dockerfile text eol=lf
docker/test-sshd/sshd_config text eol=lf
.github/** text eol=lf

*.exe binary
*.icns binary
*.ico binary
*.png binary
*.rgba binary

# Icon generator is a dev tool, not product code — keep it out of language stats.
assets/make_icon.py linguist-detectable=false
